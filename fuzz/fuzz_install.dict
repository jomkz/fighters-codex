# Install-engine tokens: the .SSF keywords the planner acts on (SSF.md) and the
# .ESA directory shape it resolves them against (ESA.md).
kw_files="INSTALL_FILES"
kw_sysfiles="INSTALL_SYSFILES"
kw_script="INSTALL_SCRIPT"
kw_skip="SKIP_ON_REMOVE"
kw_folders="CREATE_FOLDERS"
kw_default="DEFAULT_PATH"
kw_app="APP_NAME"
token_path="[INSTALL_PATH]"
glob_all="*.*"
glob_dll="*.DLL"
magic="ELECTRONIC_ARTS_ARCHIVE_FILE"
method_pkwa="PKWA"
method_null="NULL"
label_libs="FA_LIBS"
label_misc="FA_MISC"
label_exec="FA_EXECUTABLE_FILES"
