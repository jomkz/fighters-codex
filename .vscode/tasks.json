{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build fx_lib",
            "type": "shell",
            "command": "cmake --build build --target fx_lib --config Debug",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build ft",
            "type": "shell",
            "command": "cmake --build build --target ft --config Debug",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build fx-gui",
            "type": "shell",
            "command": "cmake --build build --target fx-gui --config Debug",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build all",
            "type": "shell",
            "command": "cmake --build build --config Debug",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build fx_tests",
            "type": "shell",
            "command": "cmake --build build --target fx_tests --config Release",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Run tests",
            "type": "shell",
            "command": "ctest --test-dir build -C Release --output-on-failure",
            "dependsOn": "Build fx_tests",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Run fx-gui",
            "type": "shell",
            "command": "${workspaceFolder}/build/gui/Debug/fx-gui.exe",
            "dependsOn": "Build fx-gui",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
